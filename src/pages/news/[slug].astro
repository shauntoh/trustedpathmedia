---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.jsx';
import Footer from '../../components/Footer.jsx';
import { newsEntries } from '../../data/news/index.js';
import { url } from '../../lib/url.js';

export function getStaticPaths() {
  return newsEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://toolnav.io';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': siteUrl },
        { '@type': 'ListItem', 'position': 2, 'name': 'News', 'item': `${siteUrl}/news` },
        { '@type': 'ListItem', 'position': 3, 'name': entry.title, 'item': `${siteUrl}/news/${entry.slug}` },
      ],
    },
    {
      '@type': 'NewsArticle',
      'headline': entry.title,
      'description': entry.summary,
      'datePublished': entry.date,
      'dateModified': entry.date,
      'author': { '@type': 'Organization', 'name': 'ToolNav', 'url': 'https://toolnav.io' },
      'publisher': { '@type': 'Organization', 'name': 'ToolNav', 'url': 'https://toolnav.io' },
    },
  ],
};

function formatDate(iso) {
  const [year, month, day] = iso.split('-');
  return new Date(Number(year), Number(month) - 1, Number(day))
    .toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<BaseLayout
  title={entry.title}
  description={entry.summary}
  schema={schema}
>
  <div class="min-h-screen bg-navy-900">
    <Nav client:load />

    <main class="pt-24">

      {/* Breadcrumb */}
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <nav class="flex items-center gap-2 text-xs text-slate-500">
          <a href={url('/')} class="hover:text-slate-300 transition-colors">Home</a>
          <span>/</span>
          <a href={url('/news')} class="hover:text-slate-300 transition-colors">News</a>
          <span>/</span>
          <span class="text-slate-300 truncate max-w-[200px] sm:max-w-none">{entry.title}</span>
        </nav>
      </div>

      {/* Article */}
      <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

        {/* Meta */}
        <div class="flex flex-wrap items-center gap-3 mb-5">
          <time class="text-xs text-slate-500 tabular-nums">{formatDate(entry.date)}</time>
          {entry.tags && entry.tags.map((tag: string) => (
            <span class="text-[10px] uppercase tracking-wider text-blue-400 bg-blue-950/50 border border-blue-800/30 px-2 py-0.5 rounded-full">
              {tag}
            </span>
          ))}
        </div>

        <h1 class="text-3xl sm:text-4xl font-bold text-white leading-tight tracking-tight mb-6">
          {entry.title}
        </h1>

        <p class="text-slate-300 text-lg leading-relaxed mb-6 font-medium">
          {entry.summary}
        </p>

        <div class="border-t border-white/[0.05] my-6" />

        <p class="text-slate-400 text-base leading-relaxed mb-8">
          {entry.body}
        </p>

        {/* Related review CTA */}
        {entry.relatedReviewSlug && (
          <div class="bg-navy-800/50 border border-white/[0.07] rounded-2xl p-6 mb-8">
            <p class="text-xs uppercase tracking-widest text-slate-500 mb-3">We Cover This Tool</p>
            <p class="text-white font-semibold text-base mb-1">{entry.relatedReviewName}</p>
            <p class="text-slate-400 text-sm mb-5">See our full independent review — pricing, pros and cons, and who it's best for.</p>
            <a
              href={url(`/review/${entry.relatedReviewSlug}`)}
              id={`content-news-review-cta-${entry.relatedReviewSlug}`}
              class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-blue-600/20"
            >
              Read our {entry.relatedReviewName} review
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        )}

        {/* Source link */}
        {entry.sourceUrl && (
          <a
            href={entry.sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-300 transition-colors mb-10"
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
            Source: {entry.sourceLabel}
          </a>
        )}

        <div class="border-t border-white/[0.05] pt-8" />

        {/* Navigation */}
        <div class="flex items-center mt-4">
          <a
            href={url('/news')}
            class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-white transition-colors"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
            </svg>
            All News
          </a>
        </div>

      </article>

    </main>

    <Footer />
  </div>
</BaseLayout>
