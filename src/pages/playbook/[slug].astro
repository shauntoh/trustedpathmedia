---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PlaybookPageComponent from '../../components/pages/PlaybookPage.jsx';
import releaseSong from '../../data/playbooks/release-a-song-with-suno.js';
import sideProject from '../../data/playbooks/launch-a-side-project-with-ai.js';
import learnSkillUdemy from '../../data/playbooks/learn-a-skill-with-udemy.js';
import post30Videos from '../../data/playbooks/post-30-videos-with-invideo-fiverr.js';

export function getStaticPaths() {
  return [
    { params: { slug: 'release-a-song-with-suno' }, props: { playbook: releaseSong } },
    { params: { slug: 'launch-a-side-project-with-ai' }, props: { playbook: sideProject } },
    { params: { slug: 'learn-a-skill-with-udemy' }, props: { playbook: learnSkillUdemy } },
    { params: { slug: 'post-30-videos-with-invideo-fiverr' }, props: { playbook: post30Videos } },
  ];
}

const { playbook } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  'name': playbook.title,
  'description': playbook.tagline,
  'totalTime': playbook.timeRequired,
  'step': playbook.steps.map((step, i) => ({
    '@type': 'HowToStep',
    'position': i + 1,
    'name': step.title,
    'text': step.body,
  })),
  'author': { '@type': 'Organization', 'name': 'ToolNav', 'url': 'https://toolnav.io' },
  'publisher': { '@type': 'Organization', 'name': 'ToolNav', 'url': 'https://toolnav.io' },
};
---
<BaseLayout
  title={playbook.title}
  description={playbook.tagline}
  schema={schema}
>
  <PlaybookPageComponent playbook={playbook} client:load />
</BaseLayout>
