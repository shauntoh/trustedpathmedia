---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReviewPageComponent from '../../components/pages/ReviewPage.jsx';
import claudeAi from '../../data/reviews/claude-ai.js';
import hostinger from '../../data/reviews/hostinger.js';
import nordvpn from '../../data/reviews/nordvpn.js';
import notion from '../../data/reviews/notion.js';
import grammarly from '../../data/reviews/grammarly.js';
import suno from '../../data/reviews/suno.js';
import coursera from '../../data/reviews/coursera.js';
import skillshare from '../../data/reviews/skillshare.js';
import udemy from '../../data/reviews/udemy.js';
import n8n from '../../data/reviews/n8n.js';
import fiverr from '../../data/reviews/fiverr.js';
import invideo from '../../data/reviews/invideo.js';
import chatgpt from '../../data/reviews/chatgpt.js';
import gemini from '../../data/reviews/gemini.js';
import perplexity from '../../data/reviews/perplexity.js';
import expressvpn from '../../data/reviews/expressvpn.js';
import surfshark from '../../data/reviews/surfshark.js';
import protonvpn from '../../data/reviews/protonvpn.js';

export function getStaticPaths() {
  return [
    { params: { slug: 'claude-ai' }, props: { review: claudeAi } },
    { params: { slug: 'hostinger' }, props: { review: hostinger } },
    { params: { slug: 'nordvpn' }, props: { review: nordvpn } },
    { params: { slug: 'notion' }, props: { review: notion } },
    { params: { slug: 'grammarly' }, props: { review: grammarly } },
    { params: { slug: 'suno' }, props: { review: suno } },
    { params: { slug: 'coursera' }, props: { review: coursera } },
    { params: { slug: 'skillshare' }, props: { review: skillshare } },
    { params: { slug: 'udemy' }, props: { review: udemy } },
    { params: { slug: 'n8n' }, props: { review: n8n } },
    { params: { slug: 'fiverr' }, props: { review: fiverr } },
    { params: { slug: 'invideo' }, props: { review: invideo } },
    { params: { slug: 'chatgpt' }, props: { review: chatgpt } },
    { params: { slug: 'gemini' }, props: { review: gemini } },
    { params: { slug: 'perplexity' }, props: { review: perplexity } },
    { params: { slug: 'expressvpn' }, props: { review: expressvpn } },
    { params: { slug: 'surfshark' }, props: { review: surfshark } },
    { params: { slug: 'protonvpn' }, props: { review: protonvpn } },
  ];
}

const { review } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://toolnav.io';
const categorySlug = review.category.toLowerCase().replace(/\s+/g, '-');

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': siteUrl },
        { '@type': 'ListItem', 'position': 2, 'name': review.category, 'item': `${siteUrl}/category/${categorySlug}` },
        { '@type': 'ListItem', 'position': 3, 'name': `${review.name} Review`, 'item': `${siteUrl}/review/${review.slug}` },
      ],
    },
    {
      '@type': 'Review',
      'datePublished': review.lastUpdated,
      'dateModified': review.lastUpdated,
      'itemReviewed': {
        '@type': 'SoftwareApplication',
        'name': review.name,
        'applicationCategory': 'BusinessApplication',
        'offers': {
          '@type': 'Offer',
          'description': review.pricingNote,
        },
      },
      'reviewRating': {
        '@type': 'Rating',
        'ratingValue': review.rating,
        'bestRating': '10',
        'worstRating': '0',
      },
      'author': { '@type': 'Organization', 'name': 'ToolNav', 'url': 'https://toolnav.io' },
      'publisher': { '@type': 'Organization', 'name': 'ToolNav', 'url': 'https://toolnav.io' },
      'positiveNotes': {
        '@type': 'ItemList',
        'itemListElement': review.pros.map((pro, i) => ({
          '@type': 'ListItem',
          'position': i + 1,
          'name': pro,
        })),
      },
      'negativeNotes': {
        '@type': 'ItemList',
        'itemListElement': review.cons.map((con, i) => ({
          '@type': 'ListItem',
          'position': i + 1,
          'name': con,
        })),
      },
    },
  ],
};
---
<BaseLayout
  title={`${review.name} Review`}
  description={review.metaDescription || review.description}
  schema={schema}
>
  <ReviewPageComponent review={review} client:load />
</BaseLayout>
